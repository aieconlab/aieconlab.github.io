{{ $.Scratch.Add "index" slice }}
{{ range where site.RegularPages "Section" "in" site.Params.mainSections }}

{{ $date:= .PublishDate.Format "2006년 1월 2일" }}

{{ with .Params.images }}
{{ range first 1 . }}
{{ if (fileExists (add `assets/` .)) }}
{{ $image:= resources.Get . }}
{{ $imageSM:= $image.Fill "460x200" }}
{{ $.Scratch.Set "image" $imageSM.Permalink }}
{{ else }}
{{ $.Scratch.Set "image" (. | absURL) }}
{{ end }}
{{ end }}
{{ end }}
{{ $image:= $.Scratch.Get "image" }}

{{ $categories := slice }}
{{ range .Params.categories }}{{ $categories = $categories | append (replace . "_" " ") }}{{ end }}
{{ $.Scratch.Add "index" (dict "title" .Title "date" $date "image" $image "categories" $categories "tags" .Params.tags "contents" .Plain "permalink" .RelPermalink) }}
{{ end }}
{{ $.Scratch.Get "index" | jsonify }}
